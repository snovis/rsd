{
  "name": "rsd",
  "version": "0.1.0",
  "description": "Cold-start-ready handoffs for Claude Code sessions. Call /rsd:handoff anytime, /clear, then /rsd:pickup to resume.",
  "author": {
    "name": "Scott Novis",
    "email": "scottnovis@gmail.com"
  },
  "license": "MIT",
  "repository": "https://github.com/scottnovis/rsd",
  "commands": [
    "./commands/handoff.md",
    "./commands/ho.md",
    "./commands/pickup.md",
    "./commands/pu.md"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT/hooks/context-monitor.js\""
          }
        ]
      }
    ]
  }
}
